# ─────────────────────────────────────────────────────────────
# AgriNova AI — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to GitHub!
# ─────────────────────────────────────────────────────────────

# Google Gemini API Key
# Get free key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# Flask Secret Key (use a long random string in production)
SECRET_KEY=your-super-secret-random-key-here

# data.gov.in Agmarknet API Key (for live mandi prices)
# Register FREE at: https://data.gov.in/user/register
# After login → My Account → API Key
DATA_GOV_API_KEY=your_data_gov_in_api_key_here

# ─────────────────────────────────────────────────────────────
# Email Configuration (Gmail SMTP) — for password reset
# ─────────────────────────────────────────────────────────────
# Use App Password if 2FA is enabled:
# https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here